DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_SUPABASE_HOST:5432/postgres
DEV_BEARER=devtoken123
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=8
DB_POOL_TIMEOUT_SECONDS=8
DB_POOL_MAX_IDLE_SECONDS=300
DB_STATEMENT_TIMEOUT_MS=60000
GAIA_INGEST_QUEUE_ENABLED=1
GAIA_INGEST_REDIS_QUEUE_ENABLED=0
GAIA_INGEST_REDIS_QUEUE_KEY=gaia:ingest:samples
GAIA_INGEST_MAX_ACTIVE_WRITES=4
GAIA_INGEST_BACKLOG_MAX_BATCHES=500
GAIA_INGEST_BACKLOG_RETRY_DELAY_SECONDS=1.0
GAIA_INGEST_WORKER_RETRY_DELAY=5.0
